VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_WS_BASE_URL=ws://127.0.0.1:8000
# Optional legacy override. Prefer VITE_WS_BASE_URL so /ws/analyze is derived consistently.
# VITE_BACKEND_WS_URL=ws://127.0.0.1:8000/ws/analyze
VITE_GLASSWALL_ORG_ID=dev-org
VITE_GLASSWALL_WORKSPACE_ID=dev-workspace
VITE_GLASSWALL_DEVICE_ID=browser-endpoint
VITE_GLASSWALL_SESSION_ID=browser-session
VITE_HEARTBEAT_INTERVAL_MS=15000
VITE_ADMIN_POLL_INTERVAL_MS=15000

# Backend deployment settings. Do not commit real secrets.
DATABASE_URL=sqlite:///./glasswall-dev.db
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://aalimbaba.github.io
JWT_SECRET=replace-with-a-generated-secret
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_FRAME_BYTES=2000000
HEARTBEAT_EXPIRY_SECONDS=60
